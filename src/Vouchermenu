package ui;

import java.util.Scanner;
import manager.VoucherManagement;
import model.voucher.Voucher;

public class VoucherMenu {

    private VoucherManagement voucherManagement;
    private Scanner sc;

    public VoucherMenu() {
        voucherManagement = new VoucherManagement();
        sc = new Scanner(System.in);
    }

    public void showMenu() {

        int choice;

        do {
            System.out.println("\n===== VOUCHER MENU =====");
            System.out.println("1. Add Voucher");
            System.out.println("2. Check Voucher");
            System.out.println("3. Display Voucher List");
            System.out.println("4. Count Voucher");
            System.out.println("0. Exit");
            System.out.print("Choose: ");

            choice = Integer.parseInt(sc.nextLine());

            switch (choice) {

                case 1:
                    addVoucher();
                    break;

                case 2:
                    checkVoucher();
                    break;

                case 3:
                    voucherManagement.displayVoucher();
                    break;

                case 4:
                    System.out.println("Total Voucher: "
                            + voucherManagement.countVoucher());
                    break;

                case 0:
                    System.out.println("Program Ended!");
                    break;

                default:
                    System.out.println("Invalid Choice!");
            }

        } while (choice != 0);
    }

    private void addVoucher() {

        System.out.print("Voucher Code: ");
        String code = sc.nextLine();

        System.out.print("Discount Type: ");
        String type = sc.nextLine();

        System.out.print("Discount Value: ");
        double value = Double.parseDouble(sc.nextLine());

        System.out.print("Start Date: ");
        String startDate = sc.nextLine();

        System.out.print("End Date: ");
        String endDate = sc.nextLine();

        System.out.print("Usage Limit: ");
        int limit = Integer.parseInt(sc.nextLine());

        Voucher voucher = new Voucher(
                code,
                type,
                value,
                startDate,
                endDate,
                limit,
                true
        );

        voucherManagement.addVoucher(voucher);

        System.out.println("Voucher Added Successfully!");
    }

    private void checkVoucher() {

        System.out.print("Enter Voucher Code: ");
        String code = sc.nextLine();

        if (voucherManagement.checkVoucher(code)) {
            System.out.println("Voucher Exists!");
        } else {
            System.out.println("Voucher Not Found!");
        }
    }
}
